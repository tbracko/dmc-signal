# DMS Signal Bot — copy this file to .env and fill in your values

# Telegram bot token (from @BotFather)
TG_TOKEN=your_bot_token_here

# Telegram chat ID (your user ID or group ID — get it from @userinfobot)
TG_CHATID=your_chat_id_here

# Alert preferences (true/false)
ALERT_LONG=true          # send LONG signals (FAIL TO LOSE, BLIND ENTRY)
ALERT_SHORT=true         # send SHORT signals (FAIL TO GAIN)
ALERT_ATLEVEL=false      # send AT LEVEL watch-zone alerts (noisy — off by default)
ALERT_HTF_ONLY=false     # only alert on 1D and 1H (suppress 15m + 4H)

# Minimum R:R ratio for 15m trap signals (default 1.5)
MIN_RR=1.5

# Scan interval in milliseconds (default 120000 = 2 minutes)
INTERVAL_MS=120000
